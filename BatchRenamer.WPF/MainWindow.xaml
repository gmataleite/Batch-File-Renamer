<Window x:Class="BatchRenamer.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch File Renamer" Height="450" Width="550" WindowStartupLocation="CenterScreen">

    <StackPanel Margin="20">
        <TextBlock Text="Pasta de Origem:" FontWeight="Bold" Margin="0,0,0,5"/>
        <Grid Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding SourceFolderPath, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,10,0"/>
            <Button Grid.Column="1" Content="Procurar..." Width="80" Click="BtnProcurarOrigem_Click"/>
        </Grid>

        <TextBlock Text="Pasta de Destino (Deixe em branco para usar a mesma):" FontWeight="Bold" Margin="0,0,0,5"/>
        <Grid Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding DestinationFolderPath, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,10,0"/>
            <Button Grid.Column="1" Content="Procurar..." Width="80" Click="BtnProcurarDestino_Click"/>
        </Grid>

        <TextBlock Text="Texto a ser buscado:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Padding="5"/>

        <TextBlock Text="Texto de substituição:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox Text="{Binding ReplaceText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Padding="5"/>

        <CheckBox Content="Copiar arquivos em vez de mover" IsChecked="{Binding CopyFiles}" Margin="0,0,0,20"/>

        <Button Content="PROCESSAR ARQUIVOS" Click="BtnProcessar_Click" Padding="10" FontWeight="Bold" Background="#007ACC" Foreground="White"/>

        <TextBlock Text="{Binding ResultMessage}" Margin="0,20,0,0" FontWeight="Bold" TextWrapping="Wrap" Foreground="#D9534F"/>
    </StackPanel>
</Window>